# ==========================================================================
# Vehicle Zone Intelligence — deployment environment template
# ==========================================================================
# Copy this file to deploy/.env and fill in real values. deploy/.env is
# gitignored and must NEVER be committed. start.sh sources it automatically.
#
#   cp deploy/.env.example deploy/.env
#   # edit deploy/.env, then:  ./start.sh
#
# All variables use the VZI_ prefix (read by cloud/config.py).
# ==========================================================================

# --- Database (security observation #5) -----------------------------------
# Use a UNIQUE, STRONG password and a least-privilege application DB user.
# Do NOT reuse the old default 'apexedge' credentials in production.
VZI_DB_USER=vzi_app
VZI_DB_PASSWORD=CHANGE_ME_use_a_strong_unique_password
VZI_DB_HOST=localhost
VZI_DB_PORT=5432
VZI_DB_NAME=vehicle_zone

# --- CORS (security observation #6) ---------------------------------------
# Comma-separated list of approved dashboard origins. In production this is
# the HTTPS origin operators use (served via Nginx). No wildcards.
# Example: https://vehicle-dash.example.lan
VZI_CORS_ALLOW_ORIGINS=https://ramp-congestion.ghialunifiedapps.in

# --- Reverse proxy trust (security observation #2) ------------------------
# Peers whose forwarded client-IP headers are trusted (the Nginx proxy).
# Default is loopback because Nginx runs on the same host as the app.
# VZI_TRUSTED_PROXY_IPS=127.0.0.1,::1

# --- Redis / MQTT (optional overrides) ------------------------------------
# If you enable Redis 'requirepass' (see deploy/hardening/redis-hardening.conf
# and SECURITY_RUNBOOK.md #9), include the password here:
#   VZI_REDIS_URL=redis://:CHANGE_ME_strong_redis_password@localhost:6379/1
# VZI_REDIS_URL=redis://localhost:6379/1
# VZI_MQTT_HOST=localhost
# VZI_MQTT_PORT=1883
