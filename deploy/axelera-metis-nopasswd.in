# Allow __USER__ to reset the Axelera Metis NPU without a sudo password.
#
# This grants exactly ONE command: the root-owned reset helper, with NO
# arguments (the trailing "" forbids any argument). The helper itself is the
# only privileged surface; it must be installed root-owned and not writable by
# __USER__, and it is scoped strictly to the Metis device (PCI devices bound to
# the `metis` driver) — see deploy/metis-reset.sh.
#
# This REPLACES the previous rule, which granted passwordless sudo on general
# tools with wildcards:
#     /usr/bin/tee /sys/bus/pci/devices/*/remove   # could remove ANY PCI device
#     /usr/bin/tee /sys/bus/pci/rescan
#     /usr/bin/lsof /dev/metis*
#     /usr/sbin/modprobe -r metis
# (security observation #8 — exact command, absolute path, fixed arguments,
# root-owned helper limited to Metis reset).
#
# Install (see README "One-time host setup"):
#   # 1. Install the helper root-owned, non-writable by the app user:
#   sudo install -o root -g root -m 0755 deploy/metis-reset.sh \
#       /usr/local/sbin/metis-reset.sh
#
#   # 2. Install the sudoers rule for the current user:
#   sed "s/__USER__/$USER/" deploy/axelera-metis-nopasswd.in \
#     | sudo install -o root -g root -m 0440 /dev/stdin \
#         /etc/sudoers.d/axelera-metis-nopasswd
#   sudo visudo -c        # validate syntax
#
# The target user must already be in the `sudo` group; this rule only changes
# whether a password is required for this one command.

__USER__ ALL=(root) NOPASSWD: /usr/local/sbin/metis-reset.sh ""
